{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "eslint.config.js",
    "tests/**/*.test.{js,ts}",
    "tests/setup/**/*.{js,ts}",
    "scripts/local/gui-preview.{js,ts}"
  ],
  "project": [
    "src/**/*.{js,ts}",
    "tests/**/*.{js,ts}",
    "scripts/**/*.{js,ts}",
    "tools/**/*.{js,ts}",
    "gui/**/*.{ts,tsx}"
  ],
  "eslint": false,
  "ignoreDependencies": [
    "globals"
  ],
  "ignore": [
    "src/interfaces/PlatformEvents.ts",
    "src/core/types/config-types.ts",
    "src/types/external-modules.d.ts"
  ],
  "ignoreIssues": {
    "tests/helpers/**/*.js": [
      "exports"
    ],
    "tests/helpers/**/*.ts": [
      "exports"
    ]
  }
}
