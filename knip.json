{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "eslint.config.js",
    "tests/**/*.test.ts",
    "tests/setup/**/*.ts"
  ],
  "project": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "scripts/**/*.ts",
    "tools/**/*.ts",
    "gui/**/*.{ts,tsx}"
  ],
  "eslint": false,
  "ignoreDependencies": [
    "globals"
  ],
  "ignore": [
    "src/interfaces/PlatformEvents.ts",
    "src/core/types/config-types.ts",
    "src/types/external-modules.d.ts",
    "src/utils/logger-resolver.d.ts",
    "src/auth/oauth-flow.js",
    "src/auth/twitch-oauth-scopes.js",
    "src/auth/twitch-oauth-scopes.ts",
    "src/utils/token-store.js",
    "src/utils/cheermote-processor.js",
    "tests/helpers/farewell-routing-harness.ts"
  ],
  "ignoreIssues": {
    "src/obs/connection.ts": [
      "exports"
    ],
    "src/services/innertube-instance-manager.ts": [
      "exports"
    ],
    "tests/helpers/**/*.js": [
      "exports"
    ],
    "tests/helpers/**/*.ts": [
      "exports"
    ]
  }
}
