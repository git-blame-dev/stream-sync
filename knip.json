{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "tests/**/*.test.{js,ts}",
    "tests/setup/**/*.{js,ts}",
    "scripts/local/gui-preview.{js,ts}"
  ],
  "project": [
    "src/**/*.{js,ts}",
    "tests/**/*.{js,ts}",
    "scripts/**/*.{js,ts}",
    "gui/**/*.{ts,tsx}"
  ],
  "eslint": false,
  "ignore": [
    "src/interfaces/PlatformEvents.js"
  ],
  "ignoreIssues": {
    "tests/helpers/**/*.js": [
      "exports"
    ],
    "tests/helpers/**/*.ts": [
      "exports"
    ]
  }
}
