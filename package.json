{
  "name": "stream-sync",
  "private": true,
  "description": "Chat bot with viewer count system",
  "main": "src/bootstrap.js",
  "scripts": {
    "build": "vite build --config gui/vite.config.ts",
    "dev": "vite --config gui/vite.config.ts",
    "gui:preview": "npm run build && node scripts/local/gui-preview.js",
    "start": "node src/bootstrap.js",
    "start:debug": "node src/bootstrap.js --debug",
    "start:debug:build": "npm run build && node src/bootstrap.js --debug",
    "lint": "bun scripts/lint/no-raw-timeouts.js && bun scripts/lint/no-mock-timers-in-tests.js && bun scripts/lint/no-implementation-test-patterns.js && bun scripts/lint/no-implicit-test-defaults.js && bun scripts/lint/prefer-double-bang.js && eslint \"src/**/*.js\" \"tests/**/*.js\" && knip --config knip.json --include files,unlisted,exports",
    "test": "NODE_ENV=test bun test"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "knip": "^5.61.2",
    "react-test-renderer": "^19.2.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.9.0",
    "ini": "^5.0.0",
    "obs-websocket-js": "^5.0.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "selfsigned": "^3.0.1",
    "ws": "^8.18.0",
    "youtubei.js": "^16.0.1"
  }
}
