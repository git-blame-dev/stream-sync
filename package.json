{
  "name": "stream-sync",
  "private": true,
  "description": "Chat bot with viewer count system",
  "main": "src/bootstrap.js",
  "scripts": {
    "build": "vite build --config gui/vite.config.ts",
    "dev": "vite --config gui/vite.config.ts",
    "gui:preview": "npm run build && tsx scripts/local/gui-preview.ts",
    "gui:preview:gift-animation": "npm run build && bun scripts/local/gui-gift-animation-preview.ts",
    "start": "tsx src/bootstrap.js",
    "start:debug": "tsx src/bootstrap.js --debug",
    "start:debug:build": "npm run build && tsx src/bootstrap.js --debug",
    "lint": "bun scripts/lint/no-raw-timeouts.ts && bun scripts/lint/no-mock-timers-in-tests.ts && bun scripts/lint/no-implementation-test-patterns.ts && bun scripts/lint/no-implicit-test-defaults.ts && bun scripts/lint/prefer-double-bang.ts && bun x eslint \"src/**/*.{js,ts}\" \"tests/**/*.{js,ts}\" \"scripts/**/*.{js,ts}\" \"tools/**/*.{js,ts}\" \"gui/**/*.{ts,tsx}\" && knip --config knip.json --include files,unlisted,exports",
    "typecheck:gui": "tsc --noEmit -p gui/tsconfig.json",
    "typecheck:gui-node": "tsc --noEmit -p tsconfig.json",
    "typecheck:src": "tsc --noEmit -p tsconfig.src.json",
    "typecheck:tests": "tsc --noEmit -p tsconfig.tests.json",
    "typecheck:scripts": "tsc --noEmit -p tsconfig.scripts.json",
    "typecheck:tools": "tsc --noEmit -p tsconfig.tools.json",
    "typecheck:all": "tsc --noEmit -p tsconfig.all.json",
    "test": "NODE_ENV=test bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.39.1",
    "knip": "^5.61.2",
    "react-test-renderer": "^19.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.9.0",
    "ini": "^5.0.0",
    "obs-websocket-js": "^5.0.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "selfsigned": "^3.0.1",
    "ws": "^8.18.0",
    "youtubei.js": "^16.0.1"
  }
}
