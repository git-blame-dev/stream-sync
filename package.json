{
  "name": "stream-sync",
  "private": true,
  "description": "Multi-platform livestream event pipeline for chat, TTS, viewer counts, and OBS overlays.",
  "main": "src/bootstrap.ts",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "build": "vite build --config gui/vite.config.ts",
    "build:release:linux": "bun scripts/release/build-artifact.ts linux-x64",
    "build:release:windows": "bun scripts/release/build-artifact.ts windows-x64",
    "dev": "vite --config gui/vite.config.ts",
    "gui:demo": "bun run build && tsx scripts/local/gui-demo.ts",
    "gui:preview": "bun run build && tsx scripts/local/gui-preview.ts",
    "gui:preview:gift-animation": "bun run build && bun scripts/local/gui-gift-animation-preview.ts",
    "start": "tsx src/bootstrap.ts",
    "start:debug": "tsx src/bootstrap.ts --debug",
    "start:debug:build": "bun run build && tsx src/bootstrap.ts --debug",
    "lint": "bun scripts/lint/no-raw-timeouts.ts && bun scripts/lint/no-mock-timers-in-tests.ts && bun scripts/lint/no-implementation-test-patterns.ts && bun scripts/lint/no-implicit-test-defaults.ts && bun scripts/lint/prefer-double-bang.ts && bun x eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\" \"tools/**/*.ts\" \"gui/**/*.{ts,tsx}\" && knip --config knip.json --include files,unlisted",
    "typecheck:gui": "tsc --noEmit -p gui/tsconfig.json",
    "typecheck:gui-node": "tsc --noEmit -p tsconfig.json",
    "typecheck:src": "tsc --noEmit -p tsconfig.src.json",
    "typecheck:tests": "tsc --noEmit -p tsconfig.tests.json",
    "typecheck:scripts": "tsc --noEmit -p tsconfig.scripts.json",
    "typecheck:tools": "tsc --noEmit -p tsconfig.tools.json",
    "typecheck:all": "bun run typecheck:src && bun run typecheck:tests && bun run typecheck:scripts && bun run typecheck:tools && bun run typecheck:gui && bun run typecheck:gui-node",
    "test": "NODE_ENV=test bun test",
    "test:coverage": "NODE_ENV=test bun test --coverage --coverage-reporter=text --coverage-dir=/tmp/bun-coverage tests",
    "verify": "bun run lint && bun run typecheck:all && bun run test:coverage && bun run build"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.39.1",
    "knip": "^5.61.2",
    "react-test-renderer": "^19.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.9.0",
    "ini": "^5.0.0",
    "obs-websocket-js": "^5.0.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "selfsigned": "^3.0.1",
    "ws": "^8.18.0",
    "youtubei.js": "^16.0.1"
  }
}
