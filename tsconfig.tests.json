{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "Node",
    "allowJs": false,
    "checkJs": false,
    "noEmit": true,
    "types": ["node", "bun"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx"
  },
  "include": ["tests/**/*.ts", "tests/types/**/*.d.ts"],
  "exclude": ["node_modules", "gui/dist"]
}
